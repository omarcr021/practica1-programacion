@model practica.Models.Campana

@{
    ViewData["Title"] = "Detalle de campana";

    var estadoClass = Model.Estado switch
    {
        "Vigente" => "badge-vigente",
        "Proxima" => "badge-proxima",
        _ => "badge-finalizada"
    };
}

<section class="campanas-wrap campanas-detail-wrap">
    <a asp-controller="Campanas" asp-action="Index" class="campanas-back">Volver al listado</a>

    <article class="campana-detail-card">
        <div class="campana-card-head">
            <h1>@Model.Nombre</h1>
            <span class="campana-badge @estadoClass">@Model.Estado</span>
        </div>

        <div class="campana-detail-grid">
            <div>
                <p class="k">Categoria</p>
                <p class="v">@Model.Categoria</p>
            </div>
            <div>
                <p class="k">Canal</p>
                <p class="v">@Model.Canal</p>
            </div>
            <div>
                <p class="k">Inicio</p>
                <p class="v">@Model.FechaInicio.ToString("dd 'de' MMMM 'de' yyyy")</p>
            </div>
            <div>
                <p class="k">Fin</p>
                <p class="v">@Model.FechaFin.ToString("dd 'de' MMMM 'de' yyyy")</p>
            </div>
            <div>
                <p class="k">Descuento</p>
                <p class="v">@Model.DescuentoPct.ToString("0.##")%</p>
            </div>
        </div>

        <div class="campana-description">
            <p class="k">Descripcion</p>
            <p class="v">@Model.Descripcion</p>
        </div>
    </article>
</section>