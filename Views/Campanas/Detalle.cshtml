@model practica.Models.Campana

@{
    ViewData["Title"] = "Detalle de campana";
}

<h1 class="h3 mb-3">Detalle de Campana</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Nombre</dt>
            <dd class="col-sm-9">@Model.Nombre</dd>

            <dt class="col-sm-3">Categoria</dt>
            <dd class="col-sm-9">@Model.Categoria</dd>

            <dt class="col-sm-3">Estado</dt>
            <dd class="col-sm-9">@Model.Estado</dd>

            <dt class="col-sm-3">Fecha inicio / fin</dt>
            <dd class="col-sm-9">@Model.FechaInicio.ToString("dd/MM/yyyy") - @Model.FechaFin.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Canal</dt>
            <dd class="col-sm-9">@Model.Canal</dd>

            <dt class="col-sm-3">Descuento</dt>
            <dd class="col-sm-9">@Model.DescuentoPct.ToString("0.##")%</dd>

            <dt class="col-sm-3">Descripcion</dt>
            <dd class="col-sm-9">@Model.Descripcion</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-controller="Campanas" asp-action="Index" class="btn btn-outline-secondary">Volver al listado</a>
</div>