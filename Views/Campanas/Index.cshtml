@model practica.Models.CampanasIndexViewModel

@{
    ViewData["Title"] = "Campanas";
    var hayFiltros = !string.IsNullOrWhiteSpace(Model.CategoriaSeleccionada) || !string.IsNullOrWhiteSpace(Model.EstadoSeleccionado);
}

<section class="campanas-wrap">
    <h1 class="campanas-title">@(hayFiltros ? "Filtrar Campanas" : "Campanas Comerciales")</h1>

    @if (hayFiltros)
    {
        <div class="campanas-filter-box">
            <form asp-controller="Campanas" asp-action="Index" method="get" class="campanas-filter-form">
                <div class="campanas-field">
                    <label for="categoria" class="form-label">Categoria</label>
                    <select id="categoria" name="categoria" class="form-select form-select-sm">
                        <option value="">Todas</option>
                        @foreach (var categoria in Model.Categorias)
                        {
                            <option value="@categoria" selected="@(Model.CategoriaSeleccionada == categoria)">@categoria</option>
                        }
                    </select>
                </div>

                <div class="campanas-field">
                    <label for="estado" class="form-label">Estado</label>
                    <select id="estado" name="estado" class="form-select form-select-sm">
                        <option value="">Todos</option>
                        @foreach (var estado in Model.Estados)
                        {
                            <option value="@estado" selected="@(Model.EstadoSeleccionado == estado)">@estado</option>
                        }
                    </select>
                </div>

                <div class="campanas-actions">
                    <button type="submit" class="btn btn-sm campanas-btn-orange">Filtrar</button>
                    <a asp-controller="Campanas" asp-action="Index" class="btn btn-sm campanas-btn-neutral">Limpiar</a>
                </div>
            </form>
        </div>
    }

    @if (Model.Campanas.Count == 0)
    {
        <div class="campanas-empty">No se encontraron campanas con los filtros seleccionados.</div>
    }
    else
    {
        <div class="campanas-grid">
            @foreach (var campana in Model.Campanas)
            {
                var estadoClass = campana.Estado switch
                {
                    "Vigente" => "badge-vigente",
                    "Proxima" => "badge-proxima",
                    _ => "badge-finalizada"
                };

                <article class="campana-card">
                    <div class="campana-card-head">
                        <h2>@campana.Nombre</h2>
                        <span class="campana-badge @estadoClass">@campana.Estado</span>
                    </div>

                    <p class="campana-line">@campana.Categoria <span class="sep">%</span> @campana.DescuentoPct.ToString("0.##") <span class="sep">@@</span> @campana.FechaInicio.ToString("dd MMM. yyyy")</p>
                    <p class="campana-channel">@campana.Canal</p>
                    <a asp-controller="Campanas" asp-action="Detalle" asp-route-id="@campana.Id" class="campana-detail-link">Ver detalle</a>
                </article>
            }
        </div>

        @if (hayFiltros)
        {
            <p class="campanas-count">@Model.Campanas.Count campana(s) encontrada(s)</p>
        }
    }
</section>