@model practica.Models.CampanasIndexViewModel

@{
    ViewData["Title"] = "Campanas";
}

<h1 class="h3 mb-3">Campanas Comerciales</h1>

<div class="card mb-3">
    <div class="card-body">
        <form asp-controller="Campanas" asp-action="Index" method="get" class="row g-2 align-items-end">
            <div class="col-12 col-md-4">
                <label for="categoria" class="form-label">Categoria</label>
                <select id="categoria" name="categoria" class="form-select">
                    <option value="">Todas</option>
                    @foreach (var categoria in Model.Categorias)
                    {
                        <option value="@categoria" selected="@(Model.CategoriaSeleccionada == categoria)">@categoria</option>
                    }
                </select>
            </div>

            <div class="col-12 col-md-4">
                <label for="estado" class="form-label">Estado</label>
                <select id="estado" name="estado" class="form-select">
                    <option value="">Todos</option>
                    @foreach (var estado in Model.Estados)
                    {
                        <option value="@estado" selected="@(Model.EstadoSeleccionado == estado)">@estado</option>
                    }
                </select>
            </div>

            <div class="col-12 col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Filtrar</button>
                <a asp-controller="Campanas" asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Nombre</th>
                <th>Categoria</th>
                <th>Estado</th>
                <th>Canal</th>
                <th>Descuento</th>
                <th>Fechas</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Campanas.Count == 0)
        {
            <tr>
                <td colspan="7" class="text-center text-muted">No se encontraron campanas con los filtros seleccionados.</td>
            </tr>
        }
        else
        {
            @foreach (var campana in Model.Campanas)
            {
                <tr>
                    <td>@campana.Nombre</td>
                    <td>@campana.Categoria</td>
                    <td>@campana.Estado</td>
                    <td>@campana.Canal</td>
                    <td>@campana.DescuentoPct.ToString("0.##")%</td>
                    <td>@campana.FechaInicio.ToString("dd/MM/yyyy") - @campana.FechaFin.ToString("dd/MM/yyyy")</td>
                    <td class="text-end">
                        <a asp-controller="Campanas" asp-action="Detalle" asp-route-id="@campana.Id" class="btn btn-sm btn-outline-primary">
                            Ver detalle
                        </a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>