@model IReadOnlyList<practica.Models.Campana>

@{
    ViewData["Title"] = "Campanas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Listado de Campanas Comerciales</h1>
    <span class="badge text-bg-secondary">Total: @Model.Count</span>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Nombre</th>
                <th>Categoria</th>
                <th>Estado</th>
                <th>Canal</th>
                <th>Descuento</th>
                <th>Fechas</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var campana in Model)
        {
            <tr>
                <td>@campana.Nombre</td>
                <td>@campana.Categoria</td>
                <td>
                    @if (campana.Estado == "Vigente")
                    {
                        <span class="badge text-bg-success">@campana.Estado</span>
                    }
                    else if (campana.Estado == "Proxima")
                    {
                        <span class="badge text-bg-warning">@campana.Estado</span>
                    }
                    else
                    {
                        <span class="badge text-bg-secondary">@campana.Estado</span>
                    }
                </td>
                <td>@campana.Canal</td>
                <td>@campana.DescuentoPct.ToString("0.##")%</td>
                <td>@campana.FechaInicio.ToString("dd/MM/yyyy") - @campana.FechaFin.ToString("dd/MM/yyyy")</td>
                <td class="text-end">
                    <a asp-controller="Campanas" asp-action="Details" asp-route-id="@campana.Id" class="btn btn-sm btn-outline-primary">
                        Ver detalle
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>