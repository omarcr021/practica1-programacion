@model practica.Models.CampanasResumenViewModel

@{
    ViewData["Title"] = "Resumen";
}

<section class="campanas-wrap">
    <h1 class="campanas-title">Resumen de Campanas</h1>

    <div class="resumen-grid">
        <div class="resumen-card">
            <p class="resumen-k">Total campanas</p>
            <p class="resumen-v">@Model.TotalCampanas</p>
        </div>

        <div class="resumen-card">
            <p class="resumen-k">Campanas vigentes</p>
            <p class="resumen-v text-success">@Model.CampanasVigentes</p>
        </div>

        <div class="resumen-card">
            <p class="resumen-k">Campanas proximas</p>
            <p class="resumen-v text-primary">@Model.CampanasProximas</p>
        </div>

        <div class="resumen-card">
            <p class="resumen-k">Promedio descuento</p>
            <p class="resumen-v">@Model.PromedioDescuento.ToString("0.##")%</p>
        </div>
    </div>

    <div class="resumen-card resumen-canal-card">
        <h2>Cantidad por canal</h2>
        <ul class="resumen-canal-list">
            @foreach (var item in Model.CantidadPorCanal)
            {
                <li>
                    <span>@item.Key</span>
                    <span class="resumen-canal-badge">@item.Value</span>
                </li>
            }
        </ul>
    </div>
</section>