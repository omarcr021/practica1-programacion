<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - practica</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/practica.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="portal-header">
        <div class="container-xxl portal-topbar">
            <a class="portal-brand" asp-area="" asp-controller="Campanas" asp-action="Index">RetailCam</a>
            <nav class="portal-nav" aria-label="Navegacion principal">
                <a class="portal-nav-link active" asp-area="" asp-controller="Campanas" asp-action="Index">Listado</a>
                <a class="portal-nav-link" href="#" aria-disabled="true">Filtrar</a>
                <a class="portal-nav-link" href="#" aria-disabled="true">Resumen</a>
            </nav>
        </div>
    </header>
    <div class="container-xxl">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="portal-footer">
        <div class="container-xxl">
            Portal interno de marketing - &copy; 2026 RetailCam
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
