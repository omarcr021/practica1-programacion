<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - practica</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/practica.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
        var action = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
        var categoria = Context.Request.Query["categoria"].ToString();
        var estado = Context.Request.Query["estado"].ToString();

        var enCampanas = string.Equals(controller, "Campanas", StringComparison.OrdinalIgnoreCase);
        var enListado = enCampanas && string.Equals(action, "Index", StringComparison.OrdinalIgnoreCase);
        var enFiltro = enListado && (!string.IsNullOrWhiteSpace(categoria) || !string.IsNullOrWhiteSpace(estado));
        var enResumen = enCampanas && string.Equals(action, "Resumen", StringComparison.OrdinalIgnoreCase);
    }

    <header class="portal-header">
        <div class="container-xxl portal-topbar">
            <a class="portal-brand" asp-area="" asp-controller="Campanas" asp-action="Index">RetailCam</a>
            <nav class="portal-nav" aria-label="Navegacion principal">
                <a asp-area=""
                   asp-controller="Campanas"
                   asp-action="Index"
                   class="portal-nav-link @(enListado && !enFiltro ? "active" : string.Empty)">Listado</a>
                <a asp-area=""
                   asp-controller="Campanas"
                   asp-action="Index"
                   asp-route-categoria="Electro"
                   class="portal-nav-link @(enFiltro ? "active" : string.Empty)">Filtrar</a>
                <a asp-area=""
                   asp-controller="Campanas"
                   asp-action="Resumen"
                   class="portal-nav-link @(enResumen ? "active" : string.Empty)">Resumen</a>
            </nav>
        </div>
    </header>

    <div class="container-xxl">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="portal-footer">
        <div class="container-xxl d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>Portal interno de marketing - RetailCam</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy" class="portal-footer-link">Privacidad</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
